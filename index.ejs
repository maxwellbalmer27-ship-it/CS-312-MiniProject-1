* {
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: Arial, Helvetica, sans-serif;
  background: #f4f7fb;
  color: #1f2937;
  line-height: 1.6;
}

.container {
  width: min(1100px, 92%);
  margin: 0 auto;
}

.site-header {
  background: #111827;
  color: white;
  padding: 2rem 0;
  margin-bottom: 2rem;
}

.header-content {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: center;
}

.site-header h1 {
  margin: 0;
  font-size: 2rem;
}

.site-header p {
  margin: 0.25rem 0 0;
  color: #d1d5db;
}

.home-link {
  color: white;
  text-decoration: none;
  border: 1px solid #ffffff55;
  padding: 0.6rem 1rem;
  border-radius: 10px;
}

.card,
.post-card,
.empty-state {
  background: white;
  border-radius: 16px;
  padding: 1.5rem;
  box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
}

.blog-form {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

label {
  font-weight: 700;
}

input,
textarea,
select {
  width: 100%;
  padding: 0.85rem;
  border: 1px solid #cbd5e1;
  border-radius: 10px;
  font: inherit;
}

textarea {
  resize: vertical;
}

.btn {
  border: none;
  border-radius: 10px;
  padding: 0.75rem 1rem;
  font-weight: 700;
  cursor: pointer;
  text-decoration: none;
  display: inline-block;
  text-align: center;
}

.primary {
  background: #2563eb;
  color: white;
}

.secondary {
  background: #e5e7eb;
  color: #111827;
}

.danger {
  background: #dc2626;
  color: white;
}

.filter-row {
  margin: 2rem 0 1rem;
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: end;
}

.filter-row h2 {
  margin: 0;
}

.filter-form {
  min-width: 220px;
}

.post-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1.25rem;
  margin-bottom: 2rem;
}

.post-card h3 {
  margin-bottom: 0.25rem;
  font-size: 1.35rem;
}

.author {
  color: #64748b;
  margin-top: 0;
}

.post-content {
  white-space: pre-wrap;
}

.post-meta {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  color: #64748b;
  font-size: 0.9rem;
}

.category-badge {
  background: #dbeafe;
  color: #1e40af;
  border-radius: 999px;
  padding: 0.2rem 0.6rem;
  font-weight: 700;
}

.post-actions {
  display: flex;
  gap: 0.75rem;
  align-items: center;
  flex-wrap: wrap;
}

.post-actions form {
  margin: 0;
}

.empty-state {
  text-align: center;
  color: #64748b;
  margin-bottom: 1.25rem;
}

.site-footer {
  text-align: center;
  color: #64748b;
  padding: 2rem 1rem;
}

@media (max-width: 700px) {
  .header-content,
  .filter-row {
    flex-direction: column;
    align-items: stretch;
  }

  .post-grid {
    grid-template-columns: 1fr;
  }

  .site-header h1 {
    font-size: 1.6rem;
  }
}
