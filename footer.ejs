<%- include("partials/header") %>

<main class="container">
  <section class="card">
    <h2>Edit Blog Post</h2>

    <form action="/posts/<%= post.id %>/edit" method="POST" class="blog-form">
      <label for="creator">Creator Name</label>
      <input type="text" id="creator" name="creator" value="<%= post.creator %>" required>

      <label for="title">Blog Title</label>
      <input type="text" id="title" name="title" value="<%= post.title %>" required>

      <label for="category">Category</label>
      <select id="category" name="category" required>
        <% categories.forEach((category) => { %>
          <option value="<%= category %>" <%= post.category === category ? "selected" : "" %>>
            <%= category %>
          </option>
        <% }) %>
      </select>

      <label for="content">Blog Content</label>
      <textarea id="content" name="content" rows="8" required><%= post.content %></textarea>

      <div class="post-actions">
        <button type="submit" class="btn primary">Save Changes</button>
        <a href="/" class="btn secondary">Cancel</a>
      </div>
    </form>
  </section>
</main>

<%- include("partials/footer") %>
